# ── Frontend (S3 + CloudFront) ────────────────────────────────────
AWS_S3_BUCKET=claudio-int-tools
AWS_CLOUDFRONT_ID=<from-terraform-apply>
API_BASE=https://claudio-api.int-tools.cmtelematics.com

# ── API (ECR + ECS) ──────────────────────────────────────────────
AWS_REGION=us-east-1
ECR_REPO=<account-id>.dkr.ecr.us-east-1.amazonaws.com/claudio-api
ECS_CLUSTER=internal-tools
ECS_SERVICE=claudio-api
CORS_ORIGIN=https://claudio.int-tools.cmtelematics.com

# ── Container runtime ────────────────────────────────────────────
CLAUDE_CLI_PATH=/usr/local/bin/claude
CLAUDIO_HOME=/home/appuser
CLAUDIO_MEMORY_DIR=/home/appuser/.claude/memory
PORT=3333
